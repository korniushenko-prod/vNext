{
  "target_id": "esp32.shipcontroller.v1",
  "display_name": "ESP32 ShipController Offline Adapter",
  "supported_binding_kinds": ["digital_in", "digital_out", "analog_in", "analog_out", "service", "bus"],
  "supported_channel_kinds": ["signal", "command", "state", "event", "alarm", "telemetry"],
  "supported_value_types": ["bool", "int", "float", "duration", "string", "u32"],
