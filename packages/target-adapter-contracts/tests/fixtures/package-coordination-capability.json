{
  "target_id": "esp32-basic-io",
  "display_name": "ESP32 Basic IO",
  "supported_binding_kinds": ["digital_in", "analog_in", "digital_out", "analog_out", "service"],
  "supported_channel_kinds": ["signal", "command", "state", "telemetry"],
  "supported_value_types": ["bool", "float", "string"],
  "supported_native_kinds": ["std.pump_group.v1", "std.pid_controller.v1"],
  "supported_operation_kinds": ["start_supervision", "stop_supervision", "acknowledge_faults", "reset_package_counters", "pid_autotune_proxy"],
  "supports_trace": true,
  "supports_operations": true,
  "package_coordination_support": {
    "enabled": true,
    "package_state": true,
    "summary_outputs": true,
    "aggregate_monitors": true,
    "trace_groups": true,
    "operation_proxies": true
  },
  "supports_persistence": true,
  "supports_simulation": false,
  "limits": {
    "max_instances": 64,
    "max_connections": 128,
    "max_resources": 128
  }
}
