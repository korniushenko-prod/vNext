{
  "id": "boiler_supervisor_modes_execution",
  "kind": "package_definition",
  "meta": {
    "title": "BoilerSupervisorModesExecution v1",
    "origin": "project",
    "description": "Boiler-like reference package for bounded Wave 14 package mode transition execution.",
    "domain": "boiler",
    "package_kind": "boiler_supervisor_modes_execution_v1",
    "safety_scope": "non_safety_skeleton"
  },
  "members": {
    "boiler_core_1": { "id": "boiler_core_1", "kind": "package_member", "type_ref": "project:boiler_mode_core", "title": "Boiler Mode Core" },
    "flow_guard_1": { "id": "flow_guard_1", "kind": "package_member", "type_ref": "project:flow_guard", "title": "Flow Guard" }
  },
  "signals": {},
  "mode_phase": {
    "modes": {
      "off": { "id": "off", "title": "Off", "summary": "Package is parked.", "phase_refs": ["idle"] },
      "auto": { "id": "auto", "title": "Auto", "summary": "Package is available for bounded run sequencing.", "phase_refs": ["idle", "precheck", "run"] },
      "service": { "id": "service", "title": "Service", "summary": "Package is under bounded service handling.", "phase_refs": ["shutdown"] }
    },
    "phases": {
      "idle": { "id": "idle", "title": "Idle", "summary": "Boiler lane is idle.", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "idle_out" }] },
      "precheck": { "id": "precheck", "title": "Precheck", "summary": "Boiler prerequisites are checked.", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "precheck_out" }, { "member_id": "flow_guard_1", "port_id": "source_ok" }] },
      "run": { "id": "run", "title": "Run", "summary": "Bounded run lane is active.", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "run_out" }] },
      "shutdown": { "id": "shutdown", "title": "Shutdown", "summary": "Service shutdown lane is active.", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "shutdown_out" }] }
    },
    "mode_summary": {
      "id": "mode_summary",
      "title": "Mode Summary",
      "default_mode_ref": "auto",
      "entries": {
        "off_summary": { "id": "off_summary", "mode_ref": "off", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "off_out" }], "summary": "Off remains inactive." },
        "auto_summary": { "id": "auto_summary", "mode_ref": "auto", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "auto_out" }], "summary": "Auto is the active bounded execution mode." },
        "service_summary": { "id": "service_summary", "mode_ref": "service", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "service_out" }], "summary": "Service is reserved for bounded shutdown handling." }
      }
    },
    "phase_summary": {
      "id": "phase_summary",
      "title": "Phase Summary",
      "default_phase_ref": "precheck",
      "entries": {
        "idle_summary": { "id": "idle_summary", "phase_ref": "idle", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "idle_out" }], "summary": "Idle lane is inactive." },
        "precheck_summary": { "id": "precheck_summary", "phase_ref": "precheck", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "precheck_out" }], "summary": "Precheck is the current active phase." },
        "run_summary": { "id": "run_summary", "phase_ref": "run", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "run_out" }], "summary": "Run starts only after bounded guards pass." },
        "shutdown_summary": { "id": "shutdown_summary", "phase_ref": "shutdown", "source_ports": [{ "member_id": "boiler_core_1", "port_id": "shutdown_out" }], "summary": "Shutdown is a bounded service lane." }
      }
    },
    "active_mode_ref": "auto",
    "active_phase_ref": "precheck",
    "allowed_mode_transitions": {
      "to_off": { "id": "to_off", "intent": "request_mode_change", "from_mode_ref": "auto", "to_mode_ref": "off", "guard_notes": ["bounded_operator_request"] },
      "to_service": { "id": "to_service", "intent": "request_mode_change", "from_mode_ref": "auto", "to_mode_ref": "service", "guard_notes": ["shutdown_window_required"] }
    },
    "allowed_phase_transitions": {
      "start_run": { "id": "start_run", "intent": "request_phase_start", "phase_ref": "run", "allowed_mode_refs": ["auto"], "guard_notes": ["precheck_must_be_clear"] },
      "abort_shutdown": { "id": "abort_shutdown", "intent": "request_phase_abort", "phase_ref": "shutdown", "allowed_mode_refs": ["service"], "guard_notes": ["service_operator_confirmation"] }
    },
    "package_mode_groups": {
      "availability_modes": { "id": "availability_modes", "title": "Availability Modes", "mode_refs": ["off", "auto"] }
    },
    "package_phase_groups": {
      "active_phases": { "id": "active_phases", "title": "Active Phases", "phase_refs": ["run", "shutdown"] }
    },
    "trace_groups": {
      "mode_phase_trace": {
        "id": "mode_phase_trace",
        "title": "Mode / Phase Trace",
        "signals": [
          { "member_id": "boiler_core_1", "port_id": "auto_out" },
          { "member_id": "boiler_core_1", "port_id": "run_out" }
        ]
      }
    }
  },
  "boundary_notes": [
    "Wave 14 package mode execution remains bounded and package-neutral.",
    "Boiler-like content remains reference-only and does not introduce burner safety or full sequencing."
  ]
}
