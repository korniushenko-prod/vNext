{
  "id": "run_hours_service_preset",
  "kind": "object_template",
  "base_type_ref": "library:std/run_hours_counter",
  "origin": "library_template",
  "meta": {
    "title": "Run Hours Service Preset",
    "version": "1.0.0",
    "description": "Reusable configured preset for a persisted run-hours counter."
  },
  "defaults": {
    "param_values": {
      "persist_enabled": {
        "kind": "literal",
        "value": true
      },
      "persist_period_s": {
        "kind": "literal",
        "value": 60
      },
      "rounding_mode": {
        "kind": "literal",
        "value": "tenths"
      }
    },
    "tags": {
      "service_ready": "true",
      "category": "runtime_counter"
    },
    "facet_defaults": {
      "monitor_preset": "service_runtime"
    }
  }
}
