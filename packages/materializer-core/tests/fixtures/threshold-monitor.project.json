          "title": "Threshold Monitor",
          "version": "1.0.0",
          "origin": "library",
          "library_id": "std",
          "description": "Monitors a numeric value against high, low, or window limits with hysteresis and source timeout handling."
        },
        "interface": {
          "ports": {
            "value_in": { "id": "value_in", "direction": "in", "channel_kind": "telemetry", "value_type": "float" },
            "above_out": { "id": "above_out", "direction": "out", "channel_kind": "state", "value_type": "bool" },
            "below_out": { "id": "below_out", "direction": "out", "channel_kind": "state", "value_type": "bool" },
            "in_window_out": { "id": "in_window_out", "direction": "out", "channel_kind": "state", "value_type": "bool" },
            "alarm_active": { "id": "alarm_active", "direction": "out", "channel_kind": "state", "value_type": "bool" },
            "source_ok": { "id": "source_ok", "direction": "out", "channel_kind": "state", "value_type": "bool" }
          },
          "params": {
            "mode": { "id": "mode", "value_type": "string", "default": "high", "group": "thresholds", "ui_hint": "enum", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "low" },
            "threshold_a": { "id": "threshold_a", "value_type": "float", "default": 0.0, "unit": "engineering_units", "min": -1000000, "max": 1000000, "step": 0.01, "group": "thresholds", "ui_hint": "numeric", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "low" },
            "threshold_b": { "id": "threshold_b", "value_type": "float", "default": 100.0, "unit": "engineering_units", "min": -1000000, "max": 1000000, "step": 0.01, "group": "thresholds", "ui_hint": "numeric", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "low" },
            "hysteresis": { "id": "hysteresis", "value_type": "float", "default": 0.5, "unit": "engineering_units", "min": 0, "max": 1000000, "step": 0.01, "group": "thresholds", "ui_hint": "numeric", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "low" },
            "latch_alarm": { "id": "latch_alarm", "value_type": "bool", "default": false, "group": "alarming", "ui_hint": "toggle", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "medium" },
            "timeout_ms": { "id": "timeout_ms", "value_type": "u32", "default": 5000, "unit": "ms", "min": 0, "max": 3600000, "step": 100, "group": "alarming", "ui_hint": "duration_ms", "access_role": "engineer", "live_edit_policy": "immediate", "persist_policy": "project", "recipe_scope": "instance", "danger_level": "low" }
          },
          "alarms": {}
        },
