                "id": "high_limit",
                "defaults": {
                  "mode": "high",
                  "threshold_a": 100.0,
                  "threshold_b": 100.0,
                  "hysteresis": 1.0,
                  "latch_alarm": false,
                  "timeout_ms": 5000
                }
              },
              "low_limit": {
                "id": "low_limit",
                "defaults": {
                  "mode": "low",
                  "threshold_a": 20.0,
                  "threshold_b": 20.0,
                  "hysteresis": 1.0,
                  "latch_alarm": false,
                  "timeout_ms": 5000
                }
              },
              "window_limit": {
                "id": "window_limit",
                "defaults": {
                  "mode": "window",
                  "threshold_a": 20.0,
                  "threshold_b": 80.0,
                  "hysteresis": 1.0,
                  "latch_alarm": false,
                  "timeout_ms": 5000
                }
              }
            }
