{
  "schema_version": "0.4.0",
  "meta": {
    "project_id": "boiler_package_skeleton_demo",
    "title": "Boiler Package Skeleton Demo"
  },
  "imports": {
    "libraries": ["std"],
    "packages": []
  },
  "definitions": {
    "object_types": {},
    "templates": {
      "run_hours_service_preset": {
        "id": "run_hours_service_preset",
        "kind": "object_template",
        "base_type_ref": "library:std/run_hours_counter",
        "origin": "library_template",
        "meta": {
          "title": "Run Hours Service Preset",
          "version": "1.0.0",
          "description": "Reusable configured preset for a persisted run-hours counter."
        },
        "defaults": {
          "param_values": {
            "persist_enabled": { "kind": "literal", "value": true },
            "persist_period_s": { "kind": "literal", "value": 60 },
            "rounding_mode": { "kind": "literal", "value": "tenths" }
          },
          "tags": {
            "service_ready": "true",
            "category": "runtime_counter"
          },
          "facet_defaults": {
            "monitor_preset": "service_runtime"
          }
        }
      },
      "maintenance_service_saved": {
        "id": "maintenance_service_saved",
        "kind": "object_template",
        "base_type_ref": "library:std/maintenance_counter",
        "origin": "project_saved",
        "meta": {
          "title": "Saved Maintenance Service Preset",
          "version": "1.0.0",
          "description": "Project-saved configured maintenance preset sharing the same template contract."
        },
        "defaults": {
          "param_values": {
            "service_interval": { "kind": "literal", "value": 250 },
            "warning_before": { "kind": "literal", "value": 25 },
            "overdue_margin": { "kind": "literal", "value": 10 }
          },
          "tags": {
            "origin": "project_saved",
            "category": "maintenance"
          },
          "facet_defaults": {
            "monitor_preset": "maintenance_due"
          }
        }
      }
    },
    "packages": {
      "boiler_supervisor": {
        "id": "boiler_supervisor",
        "kind": "package_definition",
        "meta": {
          "title": "Boiler Supervisor Skeleton",
          "version": "1.0.0",
          "origin": "project",
          "description": "Boiler PLC-part skeleton assembled from frozen library objects, templates, and monitoring primitives.",
          "domain": "boiler",
          "package_kind": "boiler_supervisor_skeleton_v1",
          "safety_scope": "non_safety_skeleton"
        },
        "members": {
          "pid_1": {
            "id": "pid_1",
            "kind": "package_member",
            "type_ref": "library:std/pid_controller",
            "title": "Pressure Controller"
          },
          "flowmeter_1": {
            "id": "flowmeter_1",
            "kind": "package_member",
            "type_ref": "library:std/pulse_flowmeter",
            "title": "Feedwater Flowmeter"
          },
          "run_hours_1": {
            "id": "run_hours_1",
            "kind": "package_member",
            "type_ref": "library:std/run_hours_counter",
            "template_ref": "run_hours_service_preset",
            "title": "Boiler Runtime Hours"
          },
          "maintenance_counter_1": {
            "id": "maintenance_counter_1",
            "kind": "package_member",
            "type_ref": "library:std/maintenance_counter",
            "template_ref": "maintenance_service_saved",
            "title": "Boiler Maintenance Counter"
          },
          "threshold_monitor_1": {
            "id": "threshold_monitor_1",
            "kind": "package_member",
            "type_ref": "library:std/threshold_monitor",
            "title": "Maintenance Due Monitor"
          }
        },
        "signals": {
          "sig_runtime_to_maintenance": {
            "id": "sig_runtime_to_maintenance",
            "title": "Runtime To Maintenance",
            "source": {
              "instance_id": "run_hours_1",
              "port_id": "total_seconds"
            },
            "targets": {
              "maintenance_usage": {
                "instance_id": "maintenance_counter_1",
                "port_id": "usage_total_in"
              }
            }
          },
          "sig_maintenance_remaining_to_monitor": {
            "id": "sig_maintenance_remaining_to_monitor",
            "title": "Remaining To Threshold Monitor",
            "source": {
              "instance_id": "maintenance_counter_1",
              "port_id": "remaining_out"
            },
            "targets": {
              "remaining_monitor": {
                "instance_id": "threshold_monitor_1",
                "port_id": "value_in"
              }
            }
          }
        },
        "bindings": {
          "pressure_pv_source": {
            "id": "pressure_pv_source",
            "kind": "member_port",
            "member_id": "pid_1",
            "member_port_id": "pv",
            "binding_role": "telemetry_input",
            "required": true,
            "title": "Pressure PV Source"
          },
          "pressure_mv_output": {
            "id": "pressure_mv_output",
            "kind": "member_port",
            "member_id": "pid_1",
            "member_port_id": "mv_out",
            "binding_role": "control_output",
            "required": true,
            "title": "Pressure MV Output"
          },
          "runtime_active_source": {
            "id": "runtime_active_source",
            "kind": "member_port",
            "member_id": "run_hours_1",
            "member_port_id": "active_in",
            "binding_role": "state_input",
            "required": true,
            "title": "Runtime Active Source"
          },
          "flowmeter_pulse_source": {
            "id": "flowmeter_pulse_source",
            "kind": "member_port",
            "member_id": "flowmeter_1",
            "member_port_id": "pulse_in",
            "binding_role": "telemetry_input",
            "required": true,
            "title": "Flowmeter Pulse Source"
          }
        },
        "presets": {
          "demo_defaults": {
            "id": "demo_defaults",
            "title": "Demo Defaults",
            "description": "Small package-level preset for overview and flattening checks.",
            "member_defaults": {
              "pid_1": {
                "tags": {
                  "zone": "boiler_loop"
                }
              },
              "threshold_monitor_1": {
                "tags": {
                  "importance": "warning"
                }
              }
            }
          }
        },
        "boundary_notes": [
          "This skeleton remains non-safety and excludes burner permissives, flame supervision, and shutdown logic.",
          "Package is authoring-only and must flatten into ordinary effective instances, connections, monitors, and operations."
        ]
      }
    }
  },
  "system": {
    "instances": {},
    "signals": {},
    "packages": {
      "boiler_pkg_1": {
        "id": "boiler_pkg_1",
        "kind": "package_instance",
        "package_ref": "boiler_supervisor",
        "title": "Boiler Supervisor #1",
        "preset_ref": "demo_defaults"
      }
    }
  },
  "hardware": {
    "bindings": {}
  },
  "views": {
    "screens": {}
  },
  "layouts": {
    "system": {},
    "definitions": {}
  }
}
