        "type_ref": "library:std/analog_input",
        "title": "Usage Source",
        "enabled": true,
        "param_values": {}
      },
      "maintenance_counter_1": {
        "id": "maintenance_counter_1",
        "kind": "object_instance",
        "type_ref": "library:std/maintenance_counter",
        "title": "Maintenance Counter #1",
        "enabled": true,
        "param_values": {
          "service_interval": { "kind": "literal", "value": 500.0 },
          "warning_before": { "kind": "literal", "value": 50.0 },
          "overdue_margin": { "kind": "literal", "value": 0.0 },
          "auto_rollover": { "kind": "literal", "value": false },
          "persist_enabled": { "kind": "literal", "value": true }
        }
      }
    },
    "signals": {
      "sig_usage_source_to_maintenance_counter": {
        "id": "sig_usage_source_to_maintenance_counter",
        "title": "Usage Source -> Maintenance Counter",
        "source": {
          "instance_id": "usage_source_1",
          "port_id": "value"
        },
        "targets": {
          "t1": {
            "instance_id": "maintenance_counter_1",
            "port_id": "usage_total_in"
          }
        }
      }
    }
  },
  "hardware": {
