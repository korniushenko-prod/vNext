{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@universal-plc/project-schema": ["./node_modules/@universal-plc/project-schema/dist/index.d.ts"],
      "@universal-plc/runtime-pack-schema": ["./node_modules/@universal-plc/runtime-pack-schema/dist/index.d.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ]
}