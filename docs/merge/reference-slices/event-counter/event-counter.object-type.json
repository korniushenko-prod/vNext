{
  "id": "event_counter",
  "kind": "object_type",
  "meta": {
    "title": "Event Counter",
    "version": "1.0.0",
    "origin": "library",
    "library_id": "std",
    "description": "Counts normalized events or pulses and persists the accumulated total when required."
  },
  "interface": {
    "ports": {
      "event_in": {
        "id": "event_in",
        "title": "Event Input",
        "direction": "in",
        "channel_kind": "signal",
        "value_type": "bool"
      },
      "count_out": {
        "id": "count_out",
        "title": "Count",
        "direction": "out",
        "channel_kind": "telemetry",
        "value_type": "u32"
      },
      "event_seen": {
        "id": "event_seen",
        "title": "Event Seen",
        "direction": "out",
        "channel_kind": "state",
        "value_type": "bool"
      },
      "source_ok": {
        "id": "source_ok",
        "title": "Source OK",
        "direction": "out",
        "channel_kind": "state",
        "value_type": "bool"
      }
    },
    "params": {
      "edge_mode": {
        "id": "edge_mode",
        "title": "Edge Mode",
        "description": "Selects rising, falling, or both-edge counting.",
        "value_type": "string",
        "default": "rising",
        "group": "counting",
        "ui_hint": "enum",
        "access_role": "engineer",
        "live_edit_policy": "immediate",
        "persist_policy": "project",
        "recipe_scope": "instance",
        "danger_level": "low"
      },
      "debounce_ms": {
        "id": "debounce_ms",
        "title": "Debounce",
        "description": "Suppresses bounce or very short repeated events.",
        "value_type": "u32",
        "default": 20,
        "unit": "ms",
        "min": 0,
        "max": 10000,
        "step": 1,
        "group": "counting",
        "ui_hint": "duration_ms",
        "access_role": "engineer",
        "live_edit_policy": "immediate",
        "persist_policy": "project",
        "recipe_scope": "instance",
        "danger_level": "low"
      },
      "persist_enabled": {
        "id": "persist_enabled",
        "title": "Persist Enabled",
        "description": "Stores accumulated count to non-volatile storage.",
        "value_type": "bool",
        "default": true,
        "group": "persistence",
        "ui_hint": "toggle",
        "access_role": "engineer",
        "live_edit_policy": "apply_on_restart",
        "persist_policy": "project",
        "recipe_scope": "instance",
        "danger_level": "low"
      },
      "persist_period_s": {
        "id": "persist_period_s",
        "title": "Persist Period",
        "description": "How often accumulated count is flushed when persistence is enabled.",
        "value_type": "u32",
        "default": 60,
        "unit": "s",
        "min": 1,
        "max": 86400,
        "step": 1,
        "group": "persistence",
        "ui_hint": "duration_s",
        "access_role": "engineer",
        "live_edit_policy": "apply_on_restart",
        "persist_policy": "project",
        "recipe_scope": "instance",
        "danger_level": "low"
      },
      "increment_step": {
        "id": "increment_step",
        "title": "Increment Step",
        "description": "How much the counter increases for each accepted event.",
        "value_type": "u32",
        "default": 1,
        "min": 1,
        "max": 1000,
        "step": 1,
        "group": "counting",
        "ui_hint": "numeric",
        "access_role": "engineer",
        "live_edit_policy": "immediate",
        "persist_policy": "project",
        "recipe_scope": "instance",
        "danger_level": "low"
      }
    },
    "alarms": {}
  },
  "locals": {
    "signals": {},
    "vars": {}
  },
  "implementation": {
    "native": {
      "native_kind": "std.event_counter.v1",
      "target_kinds": [
        "esp32.shipcontroller.v1"
      ],
      "config_template": "shipcontroller.event_counter.v1"
    },
    "composition": null,
    "state": null,
    "flow": null
  },
  "facets": {
    "frontends": {
      "requirements": {
        "event_source": {
          "id": "event_source",
          "kind": "event_input",
          "title": "Event Source",
          "source_ports": ["event_in"],
          "binding_kind": "digital_in",
          "channel_kind": "signal",
          "value_type": "bool",
          "required": true
        }
      }
    },
    "operations": {
      "operations": {
        "reset_counter": {
          "id": "reset_counter",
          "kind": "reset_counter",
          "title": "Reset Counter",
          "ui_hint": "danger",
          "safe_when": ["stopped"],
          "confirmation_policy": "required",
          "progress_signals": ["source_ok"],
          "result_fields": ["completed", "count_out"]
        }
      }
    },
    "monitoring": {
      "monitors": {
        "stale_source": {
          "id": "stale_source",
          "kind": "stale",
          "title": "Stale Source",
          "source_ports": ["event_in"],
          "severity": "warning",
          "status_port_id": "source_ok"
        },
        "unexpected_event_rate": {
          "id": "unexpected_event_rate",
          "kind": "rate",
          "title": "Unexpected Event Rate",
          "source_ports": ["event_in"],
          "severity": "info",
          "status_port_id": "event_seen"
        }
      }
    },
    "debug": {
      "trace_groups": {
        "counting": {
          "title": "Counting",
          "signals": ["event_in", "event_seen", "count_out"],
          "sample_hint_ms": 250,
          "chart_hint": "timeline"
        }
      }
    },
    "persistence": {
      "slots": {
        "total_count": {
          "id": "total_count",
          "slot_kind": "counter",
          "title": "Total Count",
          "nv_slot_hint": "nv.event_counter.total_count",
          "flush_policy": "periodic"
        }
      }
    },
    "templates": {
      "presets": {
        "pulse_counting": {
          "id": "pulse_counting",
          "title": "Pulse Counting",
          "defaults": {
            "edge_mode": "rising",
            "debounce_ms": 5,
            "persist_enabled": true,
            "persist_period_s": 60,
            "increment_step": 1
          }
        },
        "cycle_counting": {
          "id": "cycle_counting",
          "title": "Cycle Counting",
          "defaults": {
            "edge_mode": "both",
            "debounce_ms": 50,
            "persist_enabled": true,
            "persist_period_s": 30,
            "increment_step": 1
          }
        }
      }
    }
  },
  "diagnostics": {}
}
