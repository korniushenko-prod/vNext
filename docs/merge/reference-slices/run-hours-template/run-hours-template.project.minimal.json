{
  "schema_version": "0.4.0",
  "meta": {
    "project_id": "run_hours_template_demo",
    "title": "Run Hours Template Demo"
  },
  "imports": {
    "libraries": ["std"],
    "packages": []
  },
  "definitions": {
    "object_types": {},
    "templates": {
      "run_hours_service_preset": {
        "id": "run_hours_service_preset",
        "kind": "object_template",
        "base_type_ref": "library:std/run_hours_counter",
        "origin": "library_template",
        "meta": {
          "title": "Run Hours Service Preset",
          "version": "1.0.0",
          "description": "Reusable configured preset for a persisted run-hours counter."
        },
        "defaults": {
          "param_values": {
            "persist_enabled": {
              "kind": "literal",
              "value": true
            },
            "persist_period_s": {
              "kind": "literal",
              "value": 60
            },
            "rounding_mode": {
              "kind": "literal",
              "value": "tenths"
            }
          },
          "tags": {
            "service_ready": "true",
            "category": "runtime_counter"
          },
          "facet_defaults": {
            "monitor_preset": "service_runtime"
          }
        }
      }
    }
  },
  "system": {
    "instances": {
      "run_hours_1": {
        "id": "run_hours_1",
        "kind": "object_instance",
        "type_ref": "library:std/run_hours_counter",
        "template_ref": "run_hours_service_preset",
        "enabled": true,
        "param_values": {
          "min_active_time_ms": {
            "kind": "literal",
            "value": 2000
          }
        }
      }
    },
    "signals": {}
  },
  "hardware": {
    "bindings": {}
  },
  "views": {
    "screens": {}
