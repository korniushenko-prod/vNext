{
  "id": "boiler_supervisor_modes",
  "kind": "package_definition",
  "meta": {
    "title": "BoilerSupervisorModes v1",
    "origin": "project",
    "description": "Generic boiler-like reference package for Wave 13 package mode/phase metadata.",
    "domain": "boiler",
    "package_kind": "boiler_supervisor_modes_v1",
    "safety_scope": "non_safety_skeleton"
  },
  "members": {
    "boiler_core_1": { "id": "boiler_core_1", "kind": "package_member", "type_ref": "project:boiler_supervisor_core", "title": "Boiler Supervisor Core" },
    "flow_guard_1": { "id": "flow_guard_1", "kind": "package_member", "type_ref": "project:flow_guard", "title": "Flow Guard" },
    "maintenance_counter_1": { "id": "maintenance_counter_1", "kind": "package_member", "type_ref": "project:maintenance_counter", "title": "Boiler Maintenance Counter" }
  },
  "signals": {},
  "mode_phase": {
    "modes": {
      "off": { "id": "off", "title": "Off", "summary": "Package is parked with no active boiler demand.", "phase_refs": ["idle"] },
      "standby": { "id": "standby", "title": "Standby", "summary": "Package is healthy and waiting for supervisory run demand.", "phase_refs": ["idle", "precheck"] },
      "run": { "id": "run", "title": "Run", "summary": "Package is in active control supervision.", "phase_refs": ["precheck", "run"] }
    },
    "phases": {
      "idle": {
        "id": "idle",
        "title": "Idle",
        "summary": "Package remains available with no active run lane.",
        "source_ports": [{ "member_id": "boiler_core_1", "port_id": "idle_out" }]
      },
      "precheck": {
        "id": "precheck",
        "title": "Precheck",
        "summary": "Flow and maintenance prerequisites are evaluated before run.",
        "source_ports": [
          { "member_id": "flow_guard_1", "port_id": "source_ok" },
          { "member_id": "maintenance_counter_1", "port_id": "source_ok" }
        ]
      },
      "run": {
        "id": "run",
        "title": "Run",
        "summary": "Boiler supervisory run lane is active.",
        "source_ports": [{ "member_id": "boiler_core_1", "port_id": "run_out" }]
      }
    },
    "mode_summary": {
      "id": "mode_summary",
      "title": "Package Mode Summary",
      "default_mode_ref": "standby",
      "entries": {
        "off_summary": {
          "id": "off_summary",
          "title": "Off Summary",
          "mode_ref": "off",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "off_out" }],
          "summary": "Off lane remains inactive."
        },
        "standby_summary": {
          "id": "standby_summary",
          "title": "Standby Summary",
          "mode_ref": "standby",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "standby_out" }],
          "summary": "Standby is the current supervisory mode."
        },
        "run_summary": {
          "id": "run_summary",
          "title": "Run Summary",
          "mode_ref": "run",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "run_out" }],
          "summary": "Run mode becomes active only after precheck clears."
        }
      }
    },
    "phase_summary": {
      "id": "phase_summary",
      "title": "Package Phase Summary",
      "default_phase_ref": "precheck",
      "entries": {
        "idle_summary": {
          "id": "idle_summary",
          "title": "Idle Summary",
          "phase_ref": "idle",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "idle_out" }],
          "summary": "Idle phase is inactive."
        },
        "precheck_summary": {
          "id": "precheck_summary",
          "title": "Precheck Summary",
          "phase_ref": "precheck",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "precheck_out" }],
          "summary": "Precheck is active while supervisory gates are evaluated."
        },
        "run_phase_summary": {
          "id": "run_phase_summary",
          "title": "Run Phase Summary",
          "phase_ref": "run",
          "source_ports": [{ "member_id": "boiler_core_1", "port_id": "run_out" }],
          "summary": "Run phase follows the core run lane."
        }
      }
    },
    "active_mode_ref": "standby",
    "active_phase_ref": "precheck",
    "package_mode_groups": {
      "availability_modes": { "id": "availability_modes", "title": "Availability Modes", "mode_refs": ["off", "standby"], "summary": "Non-running supervisory modes." },
      "control_modes": { "id": "control_modes", "title": "Control Modes", "mode_refs": ["run"], "summary": "Active control supervisory mode." }
    },
    "package_phase_groups": {
      "preparation_phases": { "id": "preparation_phases", "title": "Preparation Phases", "phase_refs": ["idle", "precheck"], "summary": "Phases that prepare active supervision." },
      "active_phases": { "id": "active_phases", "title": "Active Phases", "phase_refs": ["run"], "summary": "Phases that represent active run behavior." }
    },
    "trace_groups": {
      "mode_phase_trace": {
        "id": "mode_phase_trace",
        "title": "Mode / Phase Trace",
        "signals": [
          { "member_id": "boiler_core_1", "port_id": "standby_out" },
          { "member_id": "boiler_core_1", "port_id": "run_out" },
          { "member_id": "maintenance_counter_1", "port_id": "remaining_out" }
        ]
      }
    }
  },
  "boundary_notes": [
    "BoilerSupervisorModes v1 stays boiler-like only as reference content. The package mode/phase contract itself remains generic and execution-neutral.",
    "Package mode/phase metadata remains authoring-level orchestration only and does not create a package execution kind."
  ]
}
