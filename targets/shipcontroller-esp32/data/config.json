        { "id": "boot_straps", "feature": "boot", "class": "warning", "owner": "boot", "reason": "Strapping pins, use with caution", "always_on": true, "pins": [0,2,5,12,15] },
        { "id": "oled_bus", "feature": "oled", "class": "exclusive", "owner": "oled", "reason": "Reserved by OLED bus", "always_on": false, "pins": [21,22] },
        { "id": "lora_bus", "feature": "lora", "class": "exclusive", "owner": "lora", "reason": "Reserved by LoRa radio", "always_on": false, "pins": [5,18,19,23,26,27,32,33] },
        { "id": "sd_bus", "feature": "sd", "class": "exclusive", "owner": "sd", "reason": "Reserved by SD card interface", "always_on": false, "pins": [2,13,14,15] },
        { "id": "status_led", "feature": "led", "class": "shared", "owner": "led", "reason": "On-board LED attached", "always_on": false, "pins": [25] },
        { "id": "battery_adc", "feature": "battery", "class": "warning", "owner": "battery", "reason": "Connected to battery sense divider", "always_on": false, "pins": [35] },
        { "id": "package_flash", "feature": "boot", "class": "forbidden", "owner": "flash", "reason": "Connected to package flash or internal package routing", "always_on": true, "pins": [6,7,8,11,16,17] }
      ]
    }
  },
  "boards": {
    "my_board": {
      "chip": "esp32",
      "template": "lilygo_t3_v1_6_1",
      "resources": {
        "r1": { "gpio": 25, "capabilities": ["di", "do", "pwm"] },
        "r2": { "gpio": 34, "capabilities": ["di", "ai", "counter"] }
      },
      "reserved": {
        "i2c_sda": 21,
        "i2c_scl": 22
      }
    }
  },
  "channels": {
    "relay1": { "resource": "r1", "type": "do" },
    "input1": { "resource": "r2", "type": "di" }
  },
  "blocks": {
    "timer1": {
      "type": "timer",
      "trigger": "input1",
      "output": "relay1",
      "duration_ms": 5000
    }
  }


}
