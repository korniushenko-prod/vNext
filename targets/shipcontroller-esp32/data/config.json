{
  "config_version": 2,
  "wifi": {
    "mode": "sta",
    "ssid": "CE",
    "password": "11223344",
    "ap_ssid": "ShipController",
    "ap_password": "12345678",
    "startup_policy": "sta_fallback_ap"
  },

  "oled": {
    "enabled": true,
    "show_ip_on_fallback": true,
    "sda": 21,
    "scl": 22,
    "address": 60,
    "width": 128,
    "height": 64
  },

  "lora": {
    "enabled": true,
    "sck": 5,
    "miso": 19,
    "mosi": 27,
    "cs": 18,
    "rst": 23,
    "dio0": 26,
    "dio1": 33,
    "dio2": 32
  },

  "sd": {
    "enabled": false,
    "cs": 13,
    "mosi": 15,
    "miso": 2,
    "sck": 14
  },

  "led": {
    "enabled": true,
    "pin": 25
  },

  "battery": {
    "enabled": true,
    "adc_pin": 35
  },

  "display": {
    "enabled": true,
    "driver": "ssd1306_128x64",
    "width": 128,
    "height": 64,
    "rotation": 0,
    "startup_screen": "main",
    "default_language": "ru",
    "screens": {
      "main": {
        "label": "Main",
        "group": "operator",
        "refresh_ms": 500,
        "widgets": {
          "ip_line": {
            "type": "pair",
            "label": "IP",
            "signal": "system.ip"
          },
          "title": {
            "type": "label",
            "label": "ShipController"
          },
          "relay_status": {
            "type": "pair",
            "label": "Relay",
            "signal": "relay1",
            "format": {
              "true_text": "ON",
              "false_text": "OFF"
            }
          },
          "trigger_status": {
            "type": "pair",
            "label": "Trigger",
            "signal": "input1",
            "format": {
              "true_text": "ON",
              "false_text": "OFF"
            }
          },
          "timer_remaining": {
            "type": "pair",
            "label": "Timer",
            "signal": "timer.remaining",
            "format": {
              "duration_style": "mm:ss"
            }
          },
          "flow_total": {
            "type": "pair",
            "label": "Total",
            "signal": "flow.total",
            "format": {
              "precision": 1,
              "suffix": " L"
            }
          }
        }
      }
    }
  },

  "screens": [
    {
      "items": [
        { "label": "FLOW", "source": "flow.instant" },
        { "label": "TOTAL", "source": "flow.total" },
        { "label": "TIMER", "source": "timer.remaining" }
      ]
    }
  ],

  "timer": {
    "relay1": { "pin": 25, "mode": "output" },
    "input1": { "pin": 34, "mode": "input" },
    "duration": 5000
  },
  "system": {
    "active_board": "my_board",
    "active_board_template": "lilygo_t3_v1_6_1",
    "active_chip_template": "esp32_pico_d4"
