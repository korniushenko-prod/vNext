        { "id": "flash_bus", "feature": "flash", "class": "forbidden", "owner": "flash", "reason": "Connected to flash / not for user IO", "always_on": true, "pins": [6,7,8,9,10,11] },
        { "id": "status_led", "feature": "led", "class": "shared", "owner": "led", "reason": "Typical on-board LED / board dependent", "always_on": false, "pins": [2] }
      ]
