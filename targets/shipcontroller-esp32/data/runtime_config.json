{
  "config_version": 2,
  "wifi": {
    "mode": "sta",
    "ssid": "Infinity-Starlink",
    "password": "",
    "ap_ssid": "ShipController",
    "ap_password": "12345678",
    "startup_policy": "sta_fallback_ap"
  },
  "oled": {
    "enabled": true,
    "show_ip_on_fallback": true,
    "sda": 21,
    "scl": 22,
    "address": 60,
    "width": 128,
    "height": 64
  },
  "led": {
    "enabled": true,
    "pin": 25
  },
  "display": {
    "enabled": true,
    "driver": "ssd1306_128x64",
    "width": 128,
    "height": 64,
    "rotation": 0,
    "startup_screen": "blink",
    "default_language": "ru",
    "screens": {
      "blink": {
        "label": "Blink Status",
        "group": "operator",
        "refresh_ms": 500,
        "widgets": {
          "ip_line": {
            "type": "pair",
            "label": "IP",
            "signal": "system.ip"
          },
          "relay_status": {
            "type": "pair",
            "label": "Relay",
            "signal": "relay1",
            "format": {
              "true_text": "ON",
              "false_text": "OFF"
            }
          },
          "phase_status": {
            "type": "pair",
            "label": "Phase",
            "signal": "timer.1.active",
            "format": {
              "true_text": "ON",
              "false_text": "OFF"
            }
          },
          "phase_remaining": {
            "type": "pair",
            "label": "Remain",
            "signal": "timer.1.phase_remaining",
            "format": {
              "duration_style": "mm:ss"
            }
          }
        }
      }
    }
  },
  "system": {
    "active_board": "my_board",
    "active_board_template": "lilygo_t3_v1_6_1",
    "active_chip_template": "esp32_pico_d4"
  },
  "boards": {
    "my_board": {
      "chip": "esp32",
      "template": "lilygo_t3_v1_6_1",
      "resources": {
        "r1": {
          "gpio": 25,
          "capabilities": ["di", "do", "pwm"]
        },
        "r2": {
          "gpio": 34,
          "capabilities": ["di", "ai", "counter"]
        }
      },
      "reserved": {
        "i2c_sda": 21,
        "i2c_scl": 22
      }
    }
  },
  "channels": {
    "relay1": {
      "resource": "r1",
      "type": "do",
      "inverted": false,
      "initial": false
    }
  },
  "blocks": {
    "timer1": {
      "type": "timer",
      "mode": "interval",
      "output": "relay1",
      "duration_ms": 5000,
      "period_ms": 15000,
      "start_immediately": true
    }
  }
}
