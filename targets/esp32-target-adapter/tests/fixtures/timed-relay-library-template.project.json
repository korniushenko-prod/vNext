        "id": "start_button_1",
        "kind": "object_instance",
        "type_ref": "library:std/digital_input",
        "title": "Start Button",
        "enabled": true,
        "param_values": {
          "debounce_ms": {
            "kind": "literal",
            "value": 20
          }
        }
      },
      "relay_1": {
        "id": "relay_1",
        "kind": "object_instance",
        "type_ref": "library:std/timed_relay",
        "template_ref": "timed_relay_service_preset",
        "title": "Timed Relay #1",
        "enabled": true,
        "param_values": {
          "output_inverted": {
            "kind": "literal",
            "value": false
          }
        }
      },
      "pump_contact_1": {
        "id": "pump_contact_1",
        "kind": "object_instance",
        "type_ref": "library:std/digital_output",
        "title": "Pump Contact",
        "enabled": true,
        "param_values": {
          "active_high": {
            "kind": "literal",
            "value": true
          }
        }
      }
    },
    "signals": {
      "sig_start_to_trigger": {
        "id": "sig_start_to_trigger",
        "title": "Start Button -> Timed Relay Trigger",
        "source": {
          "instance_id": "start_button_1",
          "port_id": "value"
        },
        "targets": {
          "t1": {
            "instance_id": "relay_1",
            "port_id": "trigger_cmd"
          }
        }
      },
      "sig_relay_to_output": {
        "id": "sig_relay_to_output",
        "title": "Timed Relay Output -> Pump Contact",
        "source": {
          "instance_id": "relay_1",
          "port_id": "relay_out"
        },
        "targets": {
          "t1": {
            "instance_id": "pump_contact_1",
            "port_id": "cmd"
          }
        }
      }
